{
  "manifest_version": 3,
  "name": "115Quick",
  "version": "1.1.0",
  "description": "115网盘离线下载管理工具",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_title": "打开115Quick管理面板"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
